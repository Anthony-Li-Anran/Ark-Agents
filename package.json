{
  "name": "ark-agents",
  "version": "0.2.0",
  "description": "基于罗德岛干员的 Electron 模块化多智能体桌面应用",
  "main": "scripts/main.js",
  "author": "Anthony_Li",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist": "electron-builder --publish=never"
  },
  "build": {
    "appId": "com.ark.agents",
    "productName": "Ark Agents",
    "icon": "icons/Ark-Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "scripts/**/*",
      "Amiya/**/*",
      "Texas/**/*",
      "Kaltsit/**/*",
      "Muelsyse/**/*",
      "Svrash/**/*",
      "models/**/*",
      "Models/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "models/**/*",
      "Models/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ark Agents"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.entertainment"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "@larksuiteoapi/node-sdk": "^1.66.0",
    "@pixi-spine/all-3.8": "3.1.2",
    "mammoth": "^1.6.0",
    "officeparser": "^4.0.5",
    "ollama": "^0.5.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.1",
    "pixi.js": "6.5.10",
    "plotly.js-dist-min": "^3.6.0",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "node-cron": "^3.0.3"
  }
}
